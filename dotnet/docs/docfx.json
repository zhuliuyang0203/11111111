{
  "metadata": [
    {
      "src": [
        {
          "src": "../src/webdriver",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "webdriver",
      "outputFormat": "apiPage"
    },
    {
      "src": [
        {
          "src": "../src/support",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "support",
      "outputFormat": "apiPage"
    }

  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "../../build/docs/api/dotnet",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "Selenium .NET API Docs",
      "_appLogoPath": "images/logo.svg",
      "_appFaviconPath": "images/favicon.ico",
      "_enableSearch": true
    }
  }
}
